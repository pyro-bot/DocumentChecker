# Single Docker entrypoint for frontend and backend through Nginx.
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=8000

# Default: call Ollama running on the host machine.
LLM_API_URL=
LLM_API_BASE_URL=
OPENAI_BASE_URL=
LLM_API_FORMAT=auto
AI_PROXY_KEY=
OLLAMA_API_KEY=
LLM_REQUESTS_PER_MINUTE=1
MODELS_CONFIG_FILE=./models.yaml
DOCTEMPLATES_DIR=./doctempletes
ADMIN_LOGINS=
LOG_LEVEL=INFO
DUCKDB_PATH=/app/data/document_checker.duckdb
DUCKDB_DATA_DIR=./data

# OpenAI-compatible example:
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_FORMAT=openai
# AI_PROXY_KEY=sk-...

# Ollama Cloud direct API example:
# In models.yaml, point an endpoint at https://ollama.com/api/chat
# with api_format=ollama and api_key_env=OLLAMA_API_KEY.
# OLLAMA_API_KEY=ollama-...

# Browser-side URL used by the frontend.
# Keep it relative so Nginx proxies API requests to the backend.
VITE_API_BASE_URL=/api
